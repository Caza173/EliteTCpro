{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "team_id": {
      "type": "string",
      "description": "Team this transaction belongs to (required)"
    },
    "created_by": {
      "type": "string",
      "description": "User ID who created the transaction"
    },
    "assigned_tc_id": {
      "type": "string",
      "description": "User ID of assigned TC"
    },
    "agent_id": {
      "type": "string",
      "description": "Optional: linked agent user ID"
    },
    "brokerage_id": {
      "type": "string"
    },
    "address": {
      "type": "string",
      "description": "Property address"
    },
    "client_access_code": {
      "type": "string"
    },
    "client_code": {
      "type": "string"
    },
    "agent_code": {
      "type": "string"
    },
    "claimed_at": {
      "type": "string"
    },
    "allowed_agent_code": {
      "type": "string"
    },
    "property_type": {
      "type": "string",
      "enum": [
        "residential",
        "condo",
        "land",
        "commercial",
        "multi_family",
        "other"
      ],
      "default": "residential"
    },
    "year_built": {
      "type": "number"
    },
    "deal_origin": {
      "type": "string",
      "enum": [
        "buyer",
        "listing"
      ]
    },
    "transaction_phase": {
      "type": "string",
      "enum": [
        "intake",
        "under_contract",
        "inspection",
        "financing",
        "appraisal",
        "clear_to_close",
        "closing",
        "closed"
      ],
      "default": "intake"
    },
    "transactionType": {
      "type": "string",
      "enum": [
        "buyer",
        "listing"
      ],
      "default": "buyer"
    },
    "dotloop_loop_id": {
      "type": "string"
    },
    "skyslope_transaction_id": {
      "type": "string"
    },
    "skyslope_file_guid": {
      "type": "string"
    },
    "skyslope_sale_guid": {
      "type": "string"
    },
    "skyslope_listing_guid": {
      "type": "string"
    },
    "skyslope_last_sync": {
      "type": "string"
    },
    "skyslope_sync_status": {
      "type": "string",
      "enum": [
        "pending",
        "synced",
        "error",
        "not_synced"
      ],
      "default": "not_synced"
    },
    "skyslope_sync_error": {
      "type": "string"
    },
    "buyer": {
      "type": "string"
    },
    "seller": {
      "type": "string"
    },
    "buyers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sellers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "buyers_agent_name": {
      "type": "string"
    },
    "buyers_agent_email": {
      "type": "string"
    },
    "buyers_agent_phone": {
      "type": "string"
    },
    "sellers_agent_name": {
      "type": "string"
    },
    "sellers_agent_email": {
      "type": "string"
    },
    "sellers_agent_phone": {
      "type": "string"
    },
    "buyer_brokerage": {
      "type": "string"
    },
    "seller_brokerage": {
      "type": "string"
    },
    "agent": {
      "type": "string"
    },
    "agent_email": {
      "type": "string"
    },
    "agent_company": {
      "type": "string"
    },
    "closing_title_company": {
      "type": "string"
    },
    "title_company_contact_name": {
      "type": "string"
    },
    "title_company_email": {
      "type": "string"
    },
    "title_company_phone": {
      "type": "string"
    },
    "inspector_name": {
      "type": "string"
    },
    "inspector_email": {
      "type": "string"
    },
    "inspector_phone": {
      "type": "string"
    },
    "inspector_company": {
      "type": "string"
    },
    "attorney_name": {
      "type": "string"
    },
    "attorney_email": {
      "type": "string"
    },
    "attorney_phone": {
      "type": "string"
    },
    "attorney_firm": {
      "type": "string"
    },
    "lender_name": {
      "type": "string"
    },
    "lender_email": {
      "type": "string"
    },
    "lender_phone": {
      "type": "string"
    },
    "lender_company": {
      "type": "string"
    },
    "appraiser_name": {
      "type": "string"
    },
    "appraiser_email": {
      "type": "string"
    },
    "appraiser_phone": {
      "type": "string"
    },
    "appraiser_company": {
      "type": "string"
    },
    "additional_contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      }
    },
    "mls_number": {
      "type": "string"
    },
    "commission": {
      "type": "string"
    },
    "commission_percent": {
      "type": "number"
    },
    "sale_price": {
      "type": "number"
    },
    "earnest_money_amount": {
      "type": "number",
      "description": "Earnest money deposit amount in dollars"
    },
    "client_email": {
      "type": "string"
    },
    "client_emails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "client_phone": {
      "type": "string"
    },
    "is_cash_transaction": {
      "type": "boolean",
      "default": false
    },
    "contract_date": {
      "type": "string",
      "format": "date"
    },
    "closing_date": {
      "type": "string",
      "format": "date"
    },
    "closing_time": {
      "type": "string"
    },
    "transaction_type": {
      "type": "string",
      "enum": [
        "buyer",
        "seller",
        "dual",
        "lease",
        "multifamily"
      ],
      "default": "buyer"
    },
    "template_id": {
      "type": "string"
    },
    "phase": {
      "type": "number",
      "default": 1
    },
    "phases_completed": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "completed_deadlines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "custom_deadline_labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "closed",
        "cancelled"
      ],
      "default": "pending"
    },
    "pipeline_stage": {
      "type": "string"
    },
    "health_score": {
      "type": "number",
      "default": 100
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "on_track",
        "watch",
        "at_risk"
      ],
      "default": "on_track"
    },
    "last_activity_at": {
      "type": "string"
    },
    "inspection_deadline": {
      "type": "string",
      "format": "date"
    },
    "inspection_scheduled": {
      "type": "string",
      "format": "date-time"
    },
    "inspection_completed": {
      "type": "string",
      "format": "date-time"
    },
    "inspection_time": {
      "type": "string"
    },
    "appraisal_deadline": {
      "type": "string",
      "format": "date"
    },
    "appraisal_time": {
      "type": "string"
    },
    "financing_deadline": {
      "type": "string",
      "format": "date"
    },
    "due_diligence_deadline": {
      "type": "string",
      "format": "date"
    },
    "earnest_money_deadline": {
      "type": "string",
      "format": "date"
    },
    "earnest_money_received": {
      "type": "boolean",
      "default": false
    },
    "earnest_money_received_date": {
      "type": "string",
      "format": "date"
    },
    "ctc_target": {
      "type": "string",
      "format": "date"
    },
    "agreement_expiration_deadline": {
      "type": "string",
      "format": "date"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          },
          "phase": {
            "type": "number"
          },
          "assigned_to": {
            "type": "string"
          },
          "due_date": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "phase_notify_settings": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "autoEnabled": {
            "type": "boolean",
            "default": false
          },
          "notified": {
            "type": "boolean",
            "default": false
          },
          "notifiedAt": {
            "type": "string"
          }
        }
      }
    },
    "sellerName": {
      "type": "string"
    },
    "sellerEmail": {
      "type": "string"
    },
    "sellerPhone": {
      "type": "string"
    },
    "listPrice": {
      "type": "number"
    },
    "listingDate": {
      "type": "string"
    },
    "expirationDate": {
      "type": "string"
    },
    "propertyStatus": {
      "type": "string",
      "enum": [
        "pre-listing",
        "coming-soon",
        "active",
        "under-contract",
        "closed",
        "expired",
        "withdrawn"
      ]
    },
    "occupancy": {
      "type": "string",
      "enum": [
        "owner",
        "tenant",
        "vacant"
      ]
    },
    "showingInstructions": {
      "type": "string"
    },
    "listSideCommission": {
      "type": "number"
    },
    "buyerAgentCommission": {
      "type": "number"
    },
    "photosScheduledDate": {
      "type": "string"
    },
    "goLiveDate": {
      "type": "string"
    },
    "utility_info": {
      "type": "object",
      "properties": {
        "electric_provider": {
          "type": "string"
        },
        "propane_provider": {
          "type": "string"
        },
        "oil_provider": {
          "type": "string"
        },
        "natural_gas_provider": {
          "type": "string"
        },
        "water_provider": {
          "type": "string"
        },
        "sewer_provider": {
          "type": "string"
        },
        "internet_provider": {
          "type": "string"
        },
        "trash_provider": {
          "type": "string"
        },
        "other_utility_notes": {
          "type": "string"
        }
      }
    },
    "email_tracking": {
      "type": "object",
      "properties": {
        "zillow_review_drafted_at": {
          "type": "string"
        },
        "zillow_review_sent_at": {
          "type": "string"
        },
        "zillow_review_sent_by": {
          "type": "string"
        },
        "utility_request_draft_created_at": {
          "type": "string"
        },
        "utility_request_sent_at": {
          "type": "string"
        },
        "utility_request_sent_by": {
          "type": "string"
        },
        "utility_info_received_at": {
          "type": "string"
        }
      }
    },
    "lead_paint_flag": {
      "type": "boolean",
      "default": false
    },
    "lead_paint_notified_year": {
      "type": "number"
    },
    "financing_contingency_status": {
      "type": "string"
    },
    "blocked_by_signature": {
      "type": "boolean",
      "default": false
    },
    "auto_send_signatures": {
      "type": "boolean",
      "default": false
    },
    "compliance_status": {
      "type": "string",
      "enum": [
        "pending",
        "compliant",
        "warnings",
        "failed"
      ],
      "default": "pending"
    }
  },
  "required": [
    "address",
    "agent"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": {
              "$in": [
                "owner",
                "admin"
              ]
            }
          }
        },
        {
          "data.created_by": "{{user.id}}"
        },
        {
          "data.assigned_tc_id": "{{user.id}}"
        }
      ]
    },
    "create": true,
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": {
              "$in": [
                "owner",
                "admin"
              ]
            }
          }
        },
        {
          "data.created_by": "{{user.id}}"
        },
        {
          "data.assigned_tc_id": "{{user.id}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": {
              "$in": [
                "owner",
                "admin"
              ]
            }
          }
        },
        {
          "data.created_by": "{{user.id}}"
        }
      ]
    }
  }
}